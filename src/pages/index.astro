---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="NextVolley USA" description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />

		<main>

			<!-- HERO -->
			<section>
				<h1>NextVolley USA</h1>
				<p>Volleyball recruiting service connecting athletes with college opportunities across the United States.</p>
			</section>

			<hr />

			<!-- NAV / QUICK OPTIONS -->
			<section>
				<h2>Explore</h2>

				<ul>
					<li><a href="#about">About NextVolley USA</a></li>
					<li><a href="#process">How Recruiting Works</a></li>
					<li><a href="#services">What We Help With</a></li>
					<li><a href="#faq">FAQ</a></li>
					<li><a href="#contact">Contact</a></li>
				</ul>
			</section>

			<hr />

			<!-- ABOUT -->
			<section id="about">
				<h2>About NextVolley USA</h2>
				<p>
					NextVolley USA helps volleyball athletes connect with college coaches and universities across the United States.
					We focus on creating visibility and building real recruiting opportunities for players looking to compete at the next level.
				</p>
			</section>

			<hr />

			<!-- PROCESS -->
			<section id="process">
				<h2>How Recruiting Works</h2>

				<ol>
					<li>Create your volleyball profile and highlight video</li>
					<li>Get seen by college coaches in the United States</li>
					<li>Communicate with programs and explore opportunities</li>
					<li>Receive offers and choose your school</li>
					<li>Prepare for your move and take off</li>
				</ol>
			</section>

			<hr />

			<!-- SERVICES -->
			<section id="services">
				<h2>What We Help With</h2>

				<ul>
					<li>Recruiting profile setup</li>
					<li>Highlight video guidance</li>
					<li>Coach outreach strategy</li>
					<li>College exposure support</li>
					<li>Recruiting process guidance</li>
				</ul>
			</section>

			<hr />

			<!-- FAQ -->
			<section id="faq">
				<h2>FAQ</h2>

				<p><strong>What is NextVolley USA?</strong><br />
				A volleyball recruiting service helping athletes get opportunities in the United States.</p>

				<p><strong>Who is it for?</strong><br />
				International volleyball players who want to play college volleyball in the U.S.</p>

				<p><strong>How does it work?</strong><br />
				We help create visibility and connect athletes with college coaches.</p>
			</section>

			<hr />

			<!-- CONTACT (placeholder only for now) -->
			<section id="contact">
				<h2>Contact</h2>
				<p>If you are interested in getting recruited, more information will be available here soon.</p>
			</section>

			<hr />

			<!-- FINAL CTA -->
			<section>
				<h2>Next step in your volleyball journey</h2>
				<p>Start building your path toward college volleyball in the United States with NextVolley USA.</p>
			</section>

		</main>

		<Footer />
	</body>
</html>
